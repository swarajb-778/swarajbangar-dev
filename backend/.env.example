# ════════════════════════════════════════════════════════════════════
# swarajbangar.dev backend environment configuration
# Copy this file to .env and fill in real values. .env is gitignored.
# ════════════════════════════════════════════════════════════════════

# ─── Anthropic ────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Database (Supabase Postgres + pgvector) ─────────────────────────
# Supabase Dashboard → Project → Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 6543) for serverless-style pooling.
# Keep ?sslmode=require at the end.
DATABASE_URL=postgresql://postgres.xxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Project URL: Supabase Dashboard → Project → Settings → API → Project URL
SUPABASE_URL=https://xxxxxx.supabase.co

# Anon key: safe to expose to frontend (subject to RLS policies)
SUPABASE_ANON_KEY=eyJhbGciOiJI...REPLACE_ME

# Service role key: NEVER expose to frontend. Bypasses RLS.
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...REPLACE_ME

# ─── Neo4j Aura Free ──────────────────────────────────────────────────
# Create instance at https://console.neo4j.io (200K nodes free)
# Credentials are downloaded ONCE as Neo4j-XXXX-Created-YYYY-MM-DD.txt
NEO4J_URI=neo4j+s://xxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME

# ─── Redis ────────────────────────────────────────────────────────────
# In Docker Compose, `redis` is the service name on the internal network.
# For local dev outside Docker, use redis://localhost:6379/0.
REDIS_URL=redis://redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins. MUST include the deployed Vercel URL.
CORS_ORIGINS=https://swarajbangar-dev.vercel.app,http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# debug | info | warning | error
LOG_LEVEL=info

# Daily Anthropic token budget. Soft cap enforced by Redis counter.
DAILY_TOKEN_BUDGET=100000

# ─── Optional ─────────────────────────────────────────────────────────
# Personal access token for GitHub API (boosts rate limit to 5000/hr).
# Generate at https://github.com/settings/tokens (read-only `public_repo`).
GITHUB_TOKEN=
