# swarajbangar.dev — frontend env template
# Copy to .env.local for local dev. Vercel reads its own envs from
# Project Settings → Environment Variables.

# Base URL of the FastAPI backend.
#   - Local dev:    http://localhost:8000
#   - Production:   https://api.swarajbangar.dev (Hetzner + Caddy, set later)
# Leave unset to fall through to mock data (Phase 1 behavior).
NEXT_PUBLIC_API_URL=http://localhost:8000
