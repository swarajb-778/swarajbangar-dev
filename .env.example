# swarajbangar.dev — frontend env template
# Copy to .env.local for local dev. Vercel reads its own envs from
# Project Settings → Environment Variables.

# Origin of the FastAPI backend. SERVER-ONLY (no NEXT_PUBLIC_ prefix):
# the browser never calls the backend directly — it calls same-origin
# Next.js route handlers under /api/*, which proxy here server-side.
# This is why a plain-HTTP droplet works behind an HTTPS Vercel site
# (no mixed content) and the droplet IP never reaches the browser.
#   - Local dev:    http://localhost:8000
#   - Production:   http://<DROPLET_IP>:8000  (set in Vercel env, Production)
# Leave unset to fall through to mock data (graceful demo mode).
BACKEND_ORIGIN=http://localhost:8000
